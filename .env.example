### Prompt Manager (.env)
#
# Copie ce fichier en .env puis adapte les valeurs.
# Ne commit pas .env (il est ignoré via .gitignore).
#

# Flask secret key (obligatoire en prod)
# Astuce pour en générer une:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me

# Port exposé sur ta machine (host) -> container:5000
HOST_PORT=5000

# Dossier hôte qui contient prompt_manager/
DIR_BASE=/absolute/path/to/your/base/dir
